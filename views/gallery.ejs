<div class="gallery-container">
  <header class="gallery-header">
    <h1>Gallery</h1>
    <div class="gallery-filters">
      <select id="filterType" onchange="applyFilter()">
        <option value="all">All Types</option>
        <option value="image">Images</option>
        <option value="video">Videos</option>
      </select>
    </div>
  </header>

  <div class="masonry-grid">
    <% outputs.forEach(item => { %>
      <div class="gallery-item" onclick="openPreview('<%= item.type %>', '/outputs/<%= item.type %>s/<%= item.filename %>')">
        <% if (item.type === 'video') { %>
          <div class="video-thumb">
            <div class="play-icon">▶</div>
          </div>
        <% } else { %>
          <img src="/outputs/images/<%= item.filename %>" alt="" loading="lazy">
        <% } %>
        <div class="item-overlay">
          <div class="item-meta">
            <span class="model"><%= item.model %></span>
            <span class="date"><%= new Date(item.created_at).toLocaleDateString() %></span>
          </div>
          <p class="item-prompt"><%= item.prompt %></p>
          <div class="item-actions">
            <button onclick="event.stopPropagation(); downloadFile('/outputs/<%= item.type %>s/<%= item.filename %>')" class="icon-btn" title="Download">⬇</button>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<div class="preview-modal" id="previewModal" onclick="closePreview()">
  <button class="close-btn" onclick="closePreview()">✕</button>
  <div class="preview-content" onclick="event.stopPropagation()">
    <img id="previewImage" style="display:none;max-width:90vw;max-height:90vh;border-radius:8px;">
    <video id="previewVideo" controls style="display:none;max-width:90vw;max-height:90vh;border-radius:8px;"></video>
  </div>
</div>

<script>
function openPreview(type, url) {
  const modal = document.getElementById('previewModal');
  const img = document.getElementById('previewImage');
  const vid = document.getElementById('previewVideo');
  
  if (type === 'video') {
    img.style.display = 'none';
    vid.style.display = 'block';
    vid.src = url;
    vid.play();
  } else {
    vid.style.display = 'none';
    img.style.display = 'block';
    img.src = url;
  }
  
  modal.classList.add('show');
}

function closePreview() {
  document.getElementById('previewModal').classList.remove('show');
  document.getElementById('previewVideo').pause();
}

function downloadFile(url) {
  const a = document.createElement('a');
  a.href = url;
  a.download = url.split('/').pop();
  a.click();
}

function applyFilter() {
  const type = document.getElementById('filterType').value;
  window.location.href = '/gallery?type=' + type;
}
</script>